# OKX OnchainOS Developer Portal credentials
# Get these from https://web3.okx.com/onchain-os/dev-portal
# NEVER commit actual values. This file is a template only.

OKX_API_KEY=your-api-key-here
OKX_SECRET_KEY=your-secret-key-here
OKX_PASSPHRASE=your-passphrase-here

# X Layer network
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196

# Supported tokens on X Layer
USDG_CONTRACT=0x4ae46a509f6b1d9056937ba4500cb143933d2dc8
USDT_CONTRACT=0x779ded0c9e1022225f8e0630b35a9b54be713736

# Agent home wallet (set after agentic-wallet login)
AGENT_WALLET_ADDRESS=

# LLM provider: Groq ONLY (demo hackathon scope, no fallback)
# Get free key from https://console.groq.com/keys
# Primary reasoning model: llama-3.3-70b-versatile (280 tps, quality)
# Fast fallback for pricing logic: llama-3.1-8b-instant (560 tps, throughput)
GROQ_API_KEY=
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# OKX OnchainOS MCP Server endpoint (unified Trade + Market + Balance)
OKX_MCP_SERVER_URL=https://web3.okx.com/api/v1/onchainos-mcp

# OKX Facilitator API base URL (for Seller-side verify + settle)
OKX_FACILITATOR_BASE_URL=https://web3.okx.com

# Consumer agent account ID (Account 1, created by `onchainos wallet login`)
CONSUMER_ACCOUNT_ID=

# Producer agent account ID (Account 2, created via first `onchainos wallet add`)
PRODUCER_ACCOUNT_ID=

# Sub-agent account ID (Account 3, created via second `onchainos wallet add`).
# Used by apps/subagent to switch to its own account before signing x402 payments
# to the Producer for the research-deep-dive composed service.
SUBAGENT_ACCOUNT_ID=

# Producer X Layer EVM address (from `onchainos wallet addresses` after `wallet switch <producer id>`).
# Used by x402-gate `payTo` field in Producer service routes.
PRODUCER_ADDRESS=

# Consumer X Layer EVM address (from `onchainos wallet addresses` after `wallet switch <consumer id>`).
# Used by the dashboard /api/live-balance route to query USDG balance via OKX MCP.
CONSUMER_ADDRESS=

# Sub-agent X Layer EVM address (from `onchainos wallet addresses` after `wallet switch <subagent id>`).
# Used as the `payTo` field on the research-deep-dive x402 gate. The Sub-agent
# must hold ~1 USDG to cover its own upstream payments to the Producer.
SUBAGENT_ADDRESS=

# Celina Attestation contract on X Layer (pre-deployed via CREATE2)
CELINA_ATTESTATION_ADDRESS=0x3d3AA2fad1a36fCe912f1c17F588270C5bEb810B

# Optional service URLs (default to localhost)
# PRODUCER_URL=http://localhost:3001
# SUBAGENT_URL=http://localhost:3003
